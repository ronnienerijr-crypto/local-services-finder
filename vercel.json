{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "rewrites": [
    {
      "source": "/((?!static/|favicon.ico|manifest.json|robots.txt|logo192.png|logo512.png).*)",
      "destination": "/index.html"
    }
  ]
}